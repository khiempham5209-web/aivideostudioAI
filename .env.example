APP_ENV=production
NODE_ENV=production
NODE_NO_WARNINGS=1

# Local uses 8787. Some hosts inject their own PORT; Render example uses API_PORT=10000.
API_PORT=8787

# "edge-first" actually calls Microsoft Edge TTS per selected voice (Hoai My /
# Nam Minh sound different). Default ("fallback-first") always uses the
# generic gTTS voice regardless of selection — only use that on hosts where
# Edge TTS's websocket is blocked.
EDGE_TTS_MODE=edge-first

# Private access. Required in production.
ALLOWED_EMAILS=your-gmail@gmail.com,shared-user@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-private-app-domain.com/api/auth/google/callback
APP_PUBLIC_URL=https://videostudioai-iota.vercel.app

# AI script generation
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Future cloud database/storage migration
DATABASE_URL=
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=ai-video-studio
R2_PUBLIC_BASE_URL=
